{
  "name": "WildfireIncident",
  "type": "object",
  "properties": {
    "incident_name": {
      "type": "string",
      "description": "Name of the wildfire incident"
    },
    "county_territory_id": {
      "type": "string",
      "description": "Reference to CountyTerritory (nullable if province not yet in DB)"
    },
    "country_code": {
      "type": "string"
    },
    "admin1_name": {
      "type": "string",
      "description": "Territory/province name"
    },
    "admin2_name": {
      "type": "string",
      "description": "Province/district name"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "containment_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "hectares_burned": {
      "type": "number",
      "description": "Area burned in hectares (universal metric unit)"
    },
    "acres_burned": {
      "type": "number",
      "description": "Area burned in acres (US units, kept for source data conversion)"
    },
    "responding_organizations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of organizations that responded to the incident"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "source": {
      "type": "string",
      "enum": [
        "NIFC",
        "NASA_FIRMS",
        "CAL_FIRE",
        "INCIWEB",
        "COPERNICUS_EFFIS",
        "GFW",
        "MANUAL",
        "OTHER"
      ]
    },
    "source_incident_id": {
      "type": "string",
      "description": "ID from the source system for deduplication"
    },
    "severity": {
      "type": "string",
      "enum": [
        "minor",
        "moderate",
        "major",
        "catastrophic"
      ]
    },
    "cause": {
      "type": "string",
      "description": "Original cause of the wildfire as recorded by the source system \u2014 preserved unchanged for data integrity"
    },
    "cause_cleaned": {
      "type": "string",
      "description": "Standardized/merged cause value used on user-facing pages. Original cause is preserved in the 'cause' field."
    },
    "structures_destroyed": {
      "type": "number"
    },
    "fatalities": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "incident_name",
    "country_code",
    "start_date"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}